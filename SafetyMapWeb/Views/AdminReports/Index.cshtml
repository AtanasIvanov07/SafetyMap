@model IEnumerable<SafetyMap.Core.DTOs.UserCrimeReport.PendingReportDTO>

@{
    ViewData["Title"] = "Pending Crime Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-inbox me-2 text-primary"></i>Pending Crime Reports</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible bg-dark border-success text-success fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible bg-dark border-danger text-danger fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="dashboard-card p-0 overflow-hidden border-top border-primary border-3">
    @if (!Model.Any())
    {
        <div class="alert alert-secondary border-0 bg-transparent text-center text-light m-4">
            <i class="bi bi-info-circle fs-3 d-block mb-2"></i>
            There are currently no pending crime reports.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover table-borderless mb-0 align-middle">
                <thead class="table-active">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Reporter</th>
                        <th>Location</th>
                        <th>Category</th>
                        <th>Description</th>
                        <th class="text-end pe-4">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">
                                @report.DateOfIncident.ToShortDateString()
                            </td>
                            <td>
                                <div>@report.ReporterName</div>
                                <small class="text-info">@report.ReporterEmail</small>
                            </td>
                            <td>
                                <div>@report.CityName</div>
                                @if (!string.IsNullOrEmpty(report.NeighborhoodName))
                                {
                                    <small class="text-secondary">@report.NeighborhoodName</small>
                                }
                                else
                                {
                                    <small class="text-secondary fst-italic">No neighborhood</small>
                                }
                            </td>
                            <td><span class="badge bg-primary">@report.CrimeCategoryName</span></td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#descModal-@report.Id">
                                    <i class="bi bi-text-paragraph text-light"></i> View
                                </button>
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm gap-2" role="group">
                                    <button type="button" class="btn btn-success fw-bold" title="Approve Report" data-bs-toggle="modal" data-bs-target="#approveModal-@report.Id">
                                        <i class="bi bi-check-circle"></i>
                                    </button>

                                    <button type="button" class="btn btn-danger fw-bold" title="Reject Report" data-bs-toggle="modal" data-bs-target="#rejectModal-@report.Id">
                                        <i class="bi bi-x-circle"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.Any())
{
    @foreach (var report in Model)
    {
        <!-- Description Modal -->
        <div class="modal fade" id="descModal-@report.Id" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark border-secondary">
                    <div class="modal-header border-bottom border-secondary">
                        <h5 class="modal-title font-weight-bold text-light"><i class="bi bi-info-square me-2"></i>Incident Description</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-light">
                        <p style="white-space: pre-wrap;">@report.Description</p>
                    </div>
                    <div class="modal-footer border-top border-secondary">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Approve Confirmation Modal -->
        <div class="modal fade" id="approveModal-@report.Id" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark border-success">
                    <div class="modal-header border-bottom border-secondary">
                        <h5 class="modal-title font-weight-bold text-light"><i class="bi bi-exclamation-circle text-warning me-2"></i>Confirm Approval</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-light">
                        <p>Are you sure you want to <strong>approve</strong> this report?</p>
                        <p class="mb-0 text-secondary">This incident will be permanently added to the statistics map.</p>
                    </div>
                    <div class="modal-footer border-top border-secondary">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="Approve" asp-route-id="@report.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-success fw-bold"><i class="bi bi-check-circle me-1"></i>Yes, Approve</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <!-- Reject Confirmation Modal -->
        <div class="modal fade" id="rejectModal-@report.Id" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark border-danger">
                    <div class="modal-header border-bottom border-secondary">
                        <h5 class="modal-title font-weight-bold text-light"><i class="bi bi-exclamation-triangle text-danger me-2"></i>Confirm Rejection</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-light">
                        <p>Are you sure you want to <strong>reject</strong> this report?</p>
                        <p class="mb-0 text-secondary">This will permanently delete the report and it cannot be undone.</p>
                    </div>
                    <div class="modal-footer border-top border-secondary">
                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                        <form asp-action="Reject" asp-route-id="@report.Id" method="post" class="d-inline">
                            <button type="submit" class="btn btn-danger fw-bold"><i class="bi bi-x-circle me-1"></i>Yes, Reject</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    }
}
