@{
    ViewData["Title"] = "Home";
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="row mb-5 align-items-center">
        <div class="col-md-8">
            <h1 class="display-5 text-light fw-bold mb-2">
                <i class="bi bi-shield-shaded me-3 text-primary"></i>SafetyMap
            </h1>
            <p class="lead text-light opacity-75 mb-0">
                Advanced Intelligence and Analytics for Urban Safety Management
            </p>
        </div>
        <div class="col-md-4 text-md-end mt-3 mt-md-0">
            <a asp-controller="Map" asp-action="Index" class="btn btn-primary btn-lg rounded-pill px-4 shadow-sm">
                <i class="bi bi-geo-alt me-2"></i>Launch Interactive Map
            </a>
        </div>
    </div>

    <!-- Quick Stats Row -->
    <div class="row g-4 mb-5">
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card border-bottom border-primary border-3 h-100 p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-light opacity-75 mb-1 fw-semibold text-uppercase font-monospace small">Total
                            Active Cities</p>
                        <h2 class="text-light mb-0 display-6 fw-bold">@ViewBag.TotalCities</h2>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary">
                        <i class="bi bi-buildings fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card border-bottom border-info border-3 h-100 p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-light opacity-75 mb-1 fw-semibold text-uppercase font-monospace small">Monitored
                            Zones</p>
                        <h2 class="text-light mb-0 display-6 fw-bold">@ViewBag.TotalNeighborhoods</h2>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                        <i class="bi bi-pin-map fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card border-bottom border-warning border-3 h-100 p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-light opacity-75 mb-1 fw-semibold text-uppercase font-monospace small">Recorded
                            Incidents</p>
                        <h2 class="text-light mb-0 display-6 fw-bold">@ViewBag.TotalCrimeStatistics</h2>
                    </div>
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                        <i class="bi bi-exclamation-triangle fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="dashboard-card border-bottom border-success border-3 h-100 p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-light opacity-75 mb-1 fw-semibold text-uppercase font-monospace small">Active
                            Alerts</p>
                        <h2 class="text-light mb-0 display-6 fw-bold">@ViewBag.TotalActiveAlerts</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                        <i class="bi bi-bell-fill fs-3"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Access Panels -->
    @if (User.Identity != null && User.IsInRole("Admin"))
    {
        <h4 class="text-light mb-4 border-bottom border-secondary pb-2"><i class="bi bi-grid-1x2 me-2"></i>System Modules
        </h4>

        <div class="row g-4">
            <!-- Crime Data Analyst -->
            <div class="col-md-6 col-lg-4">
                <div class="dashboard-card h-100 p-4 d-flex flex-column position-relative overflow-hidden group">
                    <div class="position-absolute text-light opacity-10"
                        style="right: 15px; top: 15px; font-size: 3.5rem; line-height: 1; z-index: 0;">
                        <i class="bi bi-bar-chart-line"></i>
                    </div>
                    <!-- Content -->
                    <div class="position-relative z-1 mb-auto">
                        <h5 class="text-info fw-bold mb-3"><i class="bi bi-graph-up text-light me-2"></i>Intelligence Hub
                        </h5>
                        <p class="text-light opacity-75 small">Access comprehensive crime statistics, identify emerging
                            trends, and analyze historical data across all registered municipalities.</p>
                    </div>
                    <div class="position-relative z-1 mt-4">
                        <a asp-controller="CrimeStatistics" asp-action="Index"
                            class="btn btn-outline-info w-100 text-light border-secondary hover-bg-info hover-text-dark transition-all">Access
                            Dashboard</a>
                    </div>
                </div>
            </div>

            <!-- Infrastructure Management -->
            <div class="col-md-6 col-lg-4">
                <div class="dashboard-card h-100 p-4 d-flex flex-column position-relative overflow-hidden group">
                    <div class="position-absolute text-light opacity-10"
                        style="right: 15px; top: 15px; font-size: 3.5rem; line-height: 1; z-index: 0;">
                        <i class="bi bi-diagram-3"></i>
                    </div>
                    <!-- Content -->
                    <div class="position-relative z-1 mb-auto">
                        <h5 class="text-primary fw-bold mb-3"><i
                                class="bi bi-globe-americas text-light me-2"></i>Infrastructure Control</h5>
                        <p class="text-light opacity-75 small">Manage core geographic entities including cities and
                            neighborhood boundaries. Vital for accurate spatial data representation.</p>
                    </div>
                    <div class="position-relative z-1 mt-4 d-flex gap-2">
                        <a asp-controller="Cities" asp-action="Index"
                            class="btn btn-outline-primary w-50 border-secondary text-light">Cities</a>
                        <a asp-controller="Neighborhoods" asp-action="Index"
                            class="btn btn-outline-primary w-50 border-secondary text-light">Zones</a>
                    </div>
                </div>
            </div>

            <!-- Communications -->
            <div class="col-md-6 col-lg-4">
                <div class="dashboard-card h-100 p-4 d-flex flex-column position-relative overflow-hidden group">
                    <div class="position-absolute text-light opacity-10"
                        style="right: 15px; top: 15px; font-size: 3.5rem; line-height: 1; z-index: 0;">
                        <i class="bi bi-broadcast"></i>
                    </div>
                    <!-- Content -->
                    <div class="position-relative z-1 mb-auto">
                        <h5 class="text-warning fw-bold mb-3"><i class="bi bi-chat-left-dots text-light me-2"></i>Alert
                            Network</h5>
                        <p class="text-light opacity-75 small">Oversee the citizen notification system. Manage user
                            subscriptions to specific neighborhood alerts and safety updates.</p>
                    </div>
                    <div class="position-relative z-1 mt-4">
                        <a asp-controller="UserSubscriptions" asp-action="Index"
                            class="btn btn-outline-warning text-light w-100 border-secondary">Manage Subscriptions</a>
                    </div>
                </div>
            </div>
        </div>
    }
    else if (User.Identity != null && User.Identity.IsAuthenticated)
    {
        <h4 class="text-light mb-4 border-bottom border-secondary pb-2"><i class="bi bi-grid-1x2 me-2"></i>My Access Hub
        </h4>

        <div class="row g-4">
            <!-- My Dashboard -->
            <div class="col-md-6">
                <div class="dashboard-card h-100 p-4 d-flex flex-column position-relative overflow-hidden group">
                    <div class="position-absolute text-light opacity-10"
                        style="right: 15px; top: 15px; font-size: 3.5rem; line-height: 1; z-index: 0;">
                        <i class="bi bi-person-badge"></i>
                    </div>
                    <!-- Content -->
                    <div class="position-relative z-1 mb-auto">
                        <h5 class="text-info fw-bold mb-3"><i class="bi bi-shield-check text-light me-2"></i>Personal
                            Dashboard</h5>
                        <p class="text-light opacity-75 small">Manage your tracked zones and view tailored safety alerts and
                            statistics exclusively for your subscribed neighborhoods.</p>
                    </div>
                    <div class="position-relative z-1 mt-4">
                        <a asp-controller="MyDashboard" asp-action="Index"
                            class="btn btn-outline-info w-100 text-light border-secondary">Open My Dashboard</a>
                    </div>
                </div>
            </div>

            <!-- Interactive Map -->
            <div class="col-md-6">
                <div class="dashboard-card h-100 p-4 d-flex flex-column position-relative overflow-hidden group">
                    <div class="position-absolute text-light opacity-10"
                        style="right: 15px; top: 15px; font-size: 3.5rem; line-height: 1; z-index: 0;">
                        <i class="bi bi-map"></i>
                    </div>
                    <!-- Content -->
                    <div class="position-relative z-1 mb-auto">
                        <h5 class="text-primary fw-bold mb-3"><i class="bi bi-geo-alt text-light me-2"></i>Interactive Map
                        </h5>
                        <p class="text-light opacity-75 small">Explore the comprehensive city map visually. Inspect crime
                            markers, compare zones, and analyze neighborhood data directly.</p>
                    </div>
                    <div class="position-relative z-1 mt-4">
                        <a asp-controller="Map" asp-action="Index"
                            class="btn btn-outline-primary w-100 border-secondary text-light">Explore Map</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
