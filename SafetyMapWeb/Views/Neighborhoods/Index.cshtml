@model IEnumerable<SafetyMapWeb.Models.Neighborhoods.NeighborhoodIndexViewModel>

@{
    ViewData["Title"] = "Neighborhoods";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-pin-map me-2"></i>Neighborhoods Directory</h1>
    <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Create New Neighborhood</a>
</div>

<div class="dashboard-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover table-borderless mb-0 align-middle">
            <thead class="table-active">
                <tr>
                    <th class="ps-4">@Html.DisplayNameFor(model => model.Name)</th>
                    <th>@Html.DisplayNameFor(model => model.SafetyRating)</th>
                    <th>@Html.DisplayNameFor(model => model.CityName)</th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="ps-4 fw-semibold">@Html.DisplayFor(modelItem => item.Name)</td>
                        <td>
                            @if (item.SafetyRating >= 7)
                            {
                                <span class="text-success fw-bold">@item.SafetyRating</span>
                            }
                            else if (item.SafetyRating >= 4)
                            {
                                <span class="text-warning fw-bold">@item.SafetyRating</span>
                            }
                            else
                            {
                                <span class="text-danger fw-bold">@item.SafetyRating</span>
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.CityName)</td>
                        <td class="text-end pe-4">
                            <div class="btn-group btn-group-sm" role="group">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-info" title="Edit"><i
                                        class="bi bi-pencil"></i></a>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light"
                                    title="Details"><i class="bi bi-info-circle"></i></a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger"
                                    title="Delete"><i class="bi bi-trash"></i></a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
