@model IEnumerable<SafetyMapWeb.Models.Users.UserListViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="row mb-4">
    <div class="col-12">
        <h2 class="text-primary d-flex align-items-center gap-2">
            <i class="bi bi-people"></i> Users
        </h2>
        <p class="text-muted">Manage registered users and view roles.</p>
    </div>
</div>

<div class="card bg-dark border-0 shadow-sm mb-4">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover mb-0 align-middle">
                <thead>
                    <tr class="border-bottom border-secondary">
                        <th class="ps-4">Nickname</th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Roles</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-medium">@user.UserName</td>
                            <td>
                                @if (string.IsNullOrWhiteSpace(user.FirstName) && string.IsNullOrWhiteSpace(user.LastName))
                                {
                                    <span class="text-muted fst-italic">Not provided</span>
                                }
                                else
                                {
                                    @($"{user.FirstName} {user.LastName}")
                                }
                            </td>
                            <td><a href="mailto:@user.Email" class="text-info text-decoration-none">@user.Email</a></td>
                            <td>
                                @if (user.Roles != null && user.Roles.Any())
                                {
                                    foreach (var role in user.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="badge bg-secondary">User</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-4 d-block mb-2"></i>
                                No users found
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
