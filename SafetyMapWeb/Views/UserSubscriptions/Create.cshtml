@model SafetyMapWeb.Models.UserSubscriptions.UserSubscriptionCreateViewModel

@{
    ViewData["Title"] = "Create Subscription";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-plus-lg me-2"></i>Create Subscription</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Directory</a>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="dashboard-card border-top border-primary border-3">
            <form asp-action="Create">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="UserId" class="form-label text-light fw-semibold"></label>
                    <input asp-for="UserId"
                        class="form-control form-control-lg font-monospace text-light bg-dark border-secondary"
                        placeholder="Enter User UUID..." autocomplete="off" />
                    <span asp-validation-for="UserId" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="NeighborhoodId" class="form-label text-light fw-semibold"></label>
                    <select asp-for="NeighborhoodId" asp-items="Model.Neighborhoods"
                        class="form-select form-select-lg bg-dark text-light border-secondary">
                        <option value="">-- Select Neighborhood --</option>
                    </select>
                    <span asp-validation-for="NeighborhoodId" class="text-danger small"></span>
                </div>

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <button type="submit" class="btn btn-primary px-4 py-2"><i
                            class="bi bi-check2-circle me-1"></i>Create Subscription</button>
                    <a asp-action="Index" class="btn btn-dark px-4 py-2"><i class="bi bi-x-circle me-1"></i>Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
