@model IEnumerable<SafetyMapWeb.Models.Cities.CityIndexViewModel>

@{
    ViewData["Title"] = "Cities";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-buildings me-2"></i>Cities Directory</h1>
</div>

<div class="dashboard-card p-0 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-dark table-hover table-borderless mb-0 align-middle">
            <thead class="table-active">
                <tr>
                    <th class="ps-4">
                        @Html.DisplayNameFor(model => model.Name)
                    </th>
                    <th>
                        @Html.DisplayNameFor(model => model.Population)
                    </th>
                    <th class="text-end pe-4">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                        <tr>
                            <td class="ps-4 fw-semibold">
                            @Html.DisplayFor(modelItem => item.Name)
                            </td>
                            <td>
                                @Html.DisplayFor(modelItem => item.Population)
                            </td>
                            <td class="text-end pe-4">
                                <div class="btn-group btn-group-sm" role="group">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-info" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-light" title="Details">
                                        <i class="bi bi-info-circle"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>
