@using SafetyMapWeb.Models
@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset password";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="dashboard-card p-4 border-top border-info border-3">
            <h2 class="text-center mb-1"><i class="bi bi-shield-lock text-info me-2"></i>Reset Password</h2>
            <p class="text-center text-light opacity-75 small mb-4">Please enter your new password below.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />

                <div class="mb-3">
                    <label asp-for="Password" class="form-label text-light">New Password</label>
                    <input asp-for="Password" class="form-control bg-dark text-light border-secondary" type="password" autocomplete="new-password" aria-required="true" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label text-light">Confirm Password</label>
                    <input asp-for="ConfirmPassword" class="form-control bg-dark text-light border-secondary" type="password" autocomplete="new-password" aria-required="true" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-info action-btn text-dark fw-bold">Reset Password</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
