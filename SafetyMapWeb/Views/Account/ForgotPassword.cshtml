@using SafetyMapWeb.Models
@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="dashboard-card p-4 border-top border-info border-3">
            <h2 class="text-center mb-1"><i class="bi bi-key text-info me-2"></i>Forgot Password</h2>
            <p class="text-center text-light opacity-75 small mb-4">Enter your email address and we'll send you a link to reset your password.</p>

            <form method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label text-light">Email Address</label>
                    <input asp-for="Email" class="form-control bg-dark text-light border-secondary" placeholder="name@example.com" autocomplete="username" aria-required="true" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-info action-btn text-dark fw-bold">Send Reset Link</button>
                </div>
                
                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none small text-info"><i class="bi bi-arrow-left me-1"></i>Back to log in</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
