@using SafetyMapWeb.Models
@model LoginWith2faViewModel
@{
    ViewData["Title"] = "Two-Factor Authentication";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="dashboard-card p-4 border-top border-warning border-3">
            <h2 class="text-center mb-1"><i class="bi bi-shield-check text-warning me-2"></i>Authentication</h2>
            <p class="text-center text-light opacity-75 small mb-4">Your login is protected with an authenticator app. Enter your authenticator code below.</p>

            <form method="post" asp-route-returnUrl="@ViewData["ReturnUrl"]">
                <input asp-for="RememberMe" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-4">
                    <label asp-for="TwoFactorCode" class="form-label text-light">Authenticator Code</label>
                    <input asp-for="TwoFactorCode" class="form-control bg-dark text-light border-secondary text-center fw-bold fs-4 tracking-wide" autocomplete="off" placeholder="123456" />
                    <span asp-validation-for="TwoFactorCode" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check d-flex justify-content-center gap-2">
                    <input class="form-check-input border-secondary" asp-for="RememberMachine" />
                    <label class="form-check-label text-light small" asp-for="RememberMachine">
                        Remember this machine
                    </label>
                </div>

                <div class="d-grid mb-3">
                    <button type="submit" class="btn btn-warning action-btn text-dark fw-bold">Verify & Log in</button>
                </div>
                
                <div class="text-center">
                    <a asp-action="Login" class="text-decoration-none small text-warning"><i class="bi bi-arrow-left me-1"></i>Back to log in</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
