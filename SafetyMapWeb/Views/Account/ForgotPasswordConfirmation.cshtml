@{
    ViewData["Title"] = "Forgot Password Confirmation";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="dashboard-card p-5 text-center border-top border-success border-3">
            <i class="bi bi-envelope-check text-success display-1 mb-3"></i>
            <h2 class="h3 mb-3 text-light">Check Your Email</h2>
            <p class="text-light opacity-75 mb-4">
                If there is an account associated with your email address, you will receive an email with a link to reset your password.
            </p>
            <a asp-action="Login" class="btn btn-outline-success">Return to Log in</a>
        </div>
    </div>
</div>
