@model IEnumerable<SafetyMap.Core.DTOs.UserCrimeReport.PendingReportDTO>

@{
    ViewData["Title"] = "My Reports";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-file-earmark-text me-2 text-primary"></i>My Crime Reports</h1>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> New Report
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible bg-dark border-success text-success fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible bg-dark border-danger text-danger fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="dashboard-card p-0 overflow-hidden border-top border-primary border-3">
    @if (!Model.Any())
    {
        <div class="text-center py-5 text-light opacity-50">
            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
            <p class="mb-0 fs-5">You haven't submitted any reports yet.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-dark table-hover table-borderless mb-0 align-middle">
                <thead class="table-active">
                    <tr>
                        <th class="ps-4">Date</th>
                        <th>Location</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Images</th>
                        <th>Description</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var report in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">
                                @report.DateOfIncident.ToShortDateString()
                            </td>
                            <td>
                                <div>@report.CityName</div>
                                @if (!string.IsNullOrEmpty(report.NeighborhoodName))
                                {
                                    <small class="text-light">@report.NeighborhoodName</small>
                                }
                            </td>
                            <td><span class="badge bg-primary">@report.CrimeCategoryName</span></td>
                            <td>
                                @{
                                    var statusClass = report.Status switch
                                    {
                                        "Approved" => "bg-success",
                                        "Rejected" => "bg-danger",
                                        _ => "bg-warning text-dark"
                                    };
                                }
                                <span class="badge @statusClass">@report.Status</span>
                            </td>
                            <td>
                                @if (report.Images.Any())
                                {
                                    <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#imagesModal-@report.Id">
                                        <i class="bi bi-images"></i> @report.Images.Count
                                    </button>
                                }
                                else
                                {
                                    <small class="text-light opacity-50 fst-italic">No images</small>
                                }
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-info" data-bs-toggle="modal" data-bs-target="#descModal-@report.Id">
                                    <i class="bi bi-text-paragraph text-light"></i> View
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.Any())
{
    @foreach (var report in Model)
    {
        <!-- Description Modal -->
        <div class="modal fade" id="descModal-@report.Id" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
            <div class="modal-dialog modal-dialog-centered">
                <div class="modal-content bg-dark border-secondary">
                    <div class="modal-header border-bottom border-secondary">
                        <h5 class="modal-title text-light"><i class="bi bi-info-square me-2"></i>Report Details</h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body text-light">
                        <p style="white-space: pre-wrap;">@report.Description</p>
                    </div>
                    <div class="modal-footer border-top border-secondary">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Images Modal -->
        @if (report.Images.Any())
        {
            <div class="modal fade" id="imagesModal-@report.Id" tabindex="-1" aria-hidden="true" data-bs-theme="dark">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content bg-dark border-secondary">
                        <div class="modal-header border-bottom border-secondary">
                            <h5 class="modal-title text-light"><i class="bi bi-images me-2"></i>Attached Photos</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="d-flex flex-wrap gap-3 justify-content-center">
                                @foreach (var img in report.Images)
                                {
                                    <div class="text-center position-relative">
                                        <a href="@img.ImageUrl" target="_blank">
                                            <img src="@img.ImageUrl" alt="Report Image" class="rounded" style="width:150px;height:150px;object-fit:cover;" />
                                        </a>
                                        @if (report.Status == "Pending")
                                        {
                                            <form asp-action="DeleteImage" method="post" class="d-inline" style="position:absolute;top:-8px;right:-8px;">
                                                <input type="hidden" name="imageId" value="@img.Id" />
                                                <button type="submit" class="btn btn-danger btn-sm rounded-circle" style="width:24px;height:24px;padding:0;font-size:12px;line-height:1;" title="Remove image" onclick="return confirm('Remove this image?');">
                                                    &times;
                                                </button>
                                            </form>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="modal-footer border-top border-secondary">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
}
