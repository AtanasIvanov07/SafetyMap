@model SafetyMap.Core.DTOs.CrimeStatistic.CrimeStatisticDTO

@{
    ViewData["Title"] = "Crime Statistic Details";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-light"><i class="bi bi-info-circle me-2"></i>Crime Statistic Details</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Directory</a>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="dashboard-card border-top border-secondary border-3">
            <h4 class="text-info mb-4">Record Info</h4>

            <dl class="row mb-0">
                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.NeighborhoodName)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.NeighborhoodName)
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.CrimeCategoryName)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    <span class="badge bg-secondary text-light">@Html.DisplayFor(model => model.CrimeCategoryName)</span>
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.Year)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.Year)
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.CountOfCrimes)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.CountOfCrimes)
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.TrendPercentage)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @if (Model.TrendPercentage > 0)
                    {
                            <span class="text-danger fw-semibold"><i class="bi bi-graph-up-arrow me-1"></i>@Html.DisplayFor(model => model.TrendPercentage)%</span>
                    }
                    else if (Model.TrendPercentage < 0)
                    {
                            <span class="text-success fw-semibold"><i class="bi bi-graph-down-arrow me-1"></i>@Html.DisplayFor(model => model.TrendPercentage)%</span>
                    }
                    else
                    {
                            <span class="text-secondary fw-semibold"><i class="bi bi-dash me-1"></i>0%</span>
                    }
                </dd>
            </dl>

            <hr class="border-secondary my-4" />

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-info text-dark px-4"><i class="bi bi-pencil me-1"></i>Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger px-4"><i class="bi bi-trash me-1"></i>Delete</a>
            </div>
        </div>
    </div>
</div>
