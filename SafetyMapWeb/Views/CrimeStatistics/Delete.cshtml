@model SafetyMap.Core.DTOs.CrimeStatistic.CrimeStatisticDTO

@{
    ViewData["Title"] = "Delete Crime Statistic";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0 text-danger"><i class="bi bi-exclamation-triangle me-2"></i>Delete Crime Statistic</h1>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back to Directory</a>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="alert alert-danger d-flex align-items-center bg-danger border-0 text-light bg-opacity-25" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
            <div>
                <strong>Warning!</strong> Are you sure you want to permanently delete this crime statistics record? This action cannot be undone.
            </div>
        </div>

        <div class="dashboard-card border-top border-danger border-3">
            <h4 class="text-danger mb-4">Record Info</h4>

            <dl class="row mb-0">
                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.NeighborhoodName)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.NeighborhoodName)
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.CrimeCategoryName)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    <span class="badge bg-secondary text-light">@Html.DisplayFor(model => model.CrimeCategoryName)</span>
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.Year)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.Year)
                </dd>

                <dt class="col-sm-4 text-light opacity-75 fw-normal mb-3">
                    @Html.DisplayNameFor(model => model.CountOfCrimes)
                </dt>
                <dd class="col-sm-8 text-light fw-semibold mb-3">
                    @Html.DisplayFor(model => model.CountOfCrimes)
                </dd>
            </dl>

            <hr class="border-secondary my-4" />

            <form asp-action="Delete" class="d-grid gap-2 d-md-flex justify-content-md-end">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-4 py-2"><i class="bi bi-trash me-1"></i>Confirm Delete</button>
                <a asp-action="Index" class="btn btn-dark px-4 py-2"><i class="bi bi-x-circle me-1"></i>Cancel</a>
            </form>
        </div>
    </div>
</div>
